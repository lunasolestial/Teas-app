# ── Server-side only (never prefix with VITE_) ────────────────────────────────
# Copy this file to .env and fill in your key.
# .env is git-ignored; .env.example is committed.

# Anthropic API key — read by server/index.js at runtime.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Notes ─────────────────────────────────────────────────────────────────────
# Do NOT add VITE_ANTHROPIC_API_KEY — that would expose the key in the browser bundle.
# The Vite frontend calls /api/ai which the proxy server handles with this key.
